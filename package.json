{
  "name": "copilot-portal-monorepo",
  "version": "0.1.0",
  "description": "Turn your GitHub Copilot subscription into your own API endpoint",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @copilot-portal/node-service dev",
    "dev:cf": "pnpm --filter @copilot-portal/cf-workers dev",
    "deploy:cf": "pnpm --filter @copilot-portal/cf-workers run deploy",
    "build": "pnpm -r build",
    "start": "pnpm --filter @copilot-portal/node-service start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.10.0"
}
