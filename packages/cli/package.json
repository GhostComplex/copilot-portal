{
  "name": "copilot-portal",
  "version": "0.1.0",
  "description": "Copilot Portal CLI - OAuth Device Flow authentication",
  "bin": {
    "copilot-portal": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "devDependencies": {
    "@types/node": "22.15.2"
  }
}
