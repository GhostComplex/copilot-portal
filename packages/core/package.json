{
  "name": "@copilot-portal/core",
  "version": "0.1.0",
  "description": "Copilot Portal shared API logic",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "hono": "4.12.9"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.2",
    "vitest": "4.1.2"
  }
}
