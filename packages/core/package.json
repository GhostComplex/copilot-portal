{
  "name": "@copilot-portal/core",
  "version": "0.1.0",
  "description": "Copilot Portal shared API logic",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:e2e": "vitest run --project e2e",
    "list-models": "vitest run --project e2e tests/e2e/list-models.e2e.test.ts --reporter=verbose",
    "test:coverage": "vitest run --project unit --coverage"
  },
  "dependencies": {
    "hono": "4.12.9"
  },
  "devDependencies": {
    "@types/node": "22.15.2",
    "@vitest/coverage-v8": "4.1.2",
    "vitest": "4.1.2"
  }
}
